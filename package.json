{
  "name": "@duta/sdk",
  "version": "0.1.5",
  "description": "Official Duta SDK — transactional email for developers.",
  "license": "MIT",
  "author": "Duta",
  "homepage": "https://duta.indra.sh",
  "repository": {
    "type": "git",
    "url": "https://github.com/indra-sh/duta-js.git"
  },
  "bugs": {
    "url": "https://github.com/indra-sh/duta-js/issues"
  },
  "keywords": [
    "duta",
    "email",
    "transactional-email",
    "ses",
    "resend-alternative"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
